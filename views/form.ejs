<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <form method="POST" action="/form" enctype="multipart/form-data">
      <input type="text" name="name" placeholder="Your Name" value="<%= data.name || '' %>">
      <input type="email" name="email" placeholder="Your Email" value="<%= data.email || '' %>">
      <div class="checkbox-container">
        <input type="checkbox" name="subscribe" <%= data.subscribe ? 'checked' : '' %>> 
        Subscribe to newsletter
      </div>
      <input type="file" name="image">
      <button type="submit">Submit</button>
    </form>
    <div>
      <h2>Uploaded image</h2>
      <% if (data.imageUrl) { %>
        <img src="<%= data.imageUrl %>" alt="Uploaded Image" style="max-width: 300px;">
      <% } %>
    </div>
    <div>
      <h2>Debug</h2>
      <% if (data) { %>
      <pre><%= JSON.stringify(data, null, 2) %></pre>
      <% } %>
    </div>
  </body>
</html>